
# This file shows example environment variables for both the backend
# service and the frontend build. In production you will normally split
# these between two separate `.env` files or configure them on the host.

# ---------- backend variables ----------
NODE_ENV=production
PORT=3000

# MongoDB connection string
MONGODB_URI=

# JWT secret used for signing tokens
JWT_SECRET=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS origin for frontend domain (e.g. https://app.whip4you.com)
CORS_ORIGIN=

# ---------- frontend variables (prefixed with VITE_) ----------
# the build will embed these values in the client bundle
VITE_API_BASE=http://localhost:3000
